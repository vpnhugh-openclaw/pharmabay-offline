{
  "name": "pharmabay-offline",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "package:mac": "electron-builder --mac",
    "package:win": "electron-builder --win"
  },
  "build": {
    "appId": "com.pharmabay.lister",
    "productName": "PharmaBay Lister",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-electron/**/*",
      "app/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "app",
        "to": "app",
        "filter": [
          "**/*"
        ]
      }
    ]
  },
